# --- DOMAIN CONFIGURATION (For production/reverse proxy routing) ---
WEB_DOMAIN=scryme.local
CRM_DOMAIN=crm.scryme.local
API_DOMAIN=api.scryme.local
ZITADEL_DOMAIN=auth.scryme.local
WINDMILL_DOMAIN=windmill.scryme.local
RUSTFS_DOMAIN=storage.scryme.local
RUSTFS_CONSOLE_DOMAIN=storage-console.scryme.local
MAILPIT_HOST=mail.scryme.local

# --- DOCKER PROXY / PLATFORM CONFIGURATION ---
PROXY_NETWORK=dokploy-network
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# --- DATABASE CONFIGURATION ---
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbpassword
POSTGRES_DB=app_db
DATABASE_URL=postgresql://dbuser:dbpassword@db:5432/app_db?schema=public

# ZITADEL DB
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=zitadelpassword
ZITADEL_DB_NAME=zitadel

# WINDMILL DB
WINDMILL_DB_USER=windmill
WINDMILL_DB_PASSWORD=windmillpassword
WINDMILL_DB_NAME=windmill

# --- REDIS CONFIGURATION ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- RABBITMQ CONFIGURATION ---
RABBITMQ_USER=scryme
RABBITMQ_PASS=rabbitmqsecret
RABBITMQ_URL=amqp://scryme:rabbitmqsecret@rabbitmq:5672

# --- REVERSE PROXY SUPPORT & COMPATIBILITY ---
# Tells Better-Auth to trust the headers forwarded by proxies like Traefik or Caddy
BETTER_AUTH_TRUST_HOST=true
# Point BETTER_AUTH_URL to the external user-facing site
BETTER_AUTH_URL=http://localhost:3000
# Tells the NestJS API server to trust proxy headers
TRUST_PROXY=true

# --- SERVICE PORT CONFIGURATION ---
API_PORT=4000
WEB_PORT=3000
CRM_PORT=3001
BAKERY_PORT=3003

# --- API CONFIGURATION ---
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_CRM_URL=http://localhost:3001

# --- ZITADEL CONFIGURATION (Managed Externally) ---
ZITADEL_MASTERKEY=masterkey1234567890masterkey12
ZITADEL_API_URL=https://zitadel.example.com
ZITADEL_ORG_ID=org-id
ZITADEL_PROJECT_ID=project-id
ZITADEL_CLIENT_ID=client-id

# --- OPENOBSERVE CONFIGURATION ---
OPENOBSERVE_URL=https://api.openobserve.ai
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=default
OPENOBSERVE_TOKEN=your-token

# --- SECURITY CONFIGURATION ---
JWT_SECRET=jwtsecret1234567890jwtsecret
BETTER_AUTH_SECRET=betterauthsecret1234567890secret
INTERNAL_ADMIN_SECRET=adminsecret1234567890secret
ENCRYPTION_KEY=encryptionkey1234567890key12345

# --- STORAGE CONFIGURATION ---
STORAGE_PROVIDER=rustfs # options: sanity, rustfs

# Sanity Configuration
SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=your-dataset
SANITY_API_TOKEN=your-api-token
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=your-dataset

# RustFS (S3 Compatible) Configuration
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=your-access-key
RUSTFS_SECRET_KEY=your-secret-key
RUSTFS_REGION=us-east-1
RUSTFS_BUCKET=dealio-uploads
RUSTFS_FORCE_PATH_STYLE=true
RUSTFS_PUBLIC_URL=http://localhost:9000

# --- REALTIME CONFIGURATION ---
# Provider can be 'ably' or 'socketio'
REALTIME_PROVIDER=socketio
NEXT_PUBLIC_REALTIME_PROVIDER=socketio

# Ably Configuration
ABLY_API_KEY=your-ably-api-key

# Socket.io Configuration
# For the API (server-side)
SOCKET_URL=http://localhost:3002
# For the frontend (client-side)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002

# --- WINDMILL CONFIGURATION ---
WINDMILL_INTERNAL_URL=http://windmill-server:8000
