# Database Configuration
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbpassword
POSTGRES_DB=app_db
DATABASE_URL=postgresql://dbuser:dbpassword@db:5432/app_db?schema=public

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_CRM_URL=http://localhost:3001

# Zitadel Configuration (Managed Externally)
ZITADEL_API_URL=https://zitadel.example.com
ZITADEL_ORG_ID=org-id
ZITADEL_PROJECT_ID=project-id
ZITADEL_CLIENT_ID=client-id

# OpenObserve Configuration
OPENOBSERVE_URL=https://api.openobserve.ai
OPENOBSERVE_ORG=default
OPENOBSERVE_STREAM=default
OPENOBSERVE_TOKEN=your-token

# Storage Configuration
STORAGE_PROVIDER=sanity # options: sanity, rustfs

# Sanity Configuration
SANITY_PROJECT_ID=your-project-id
SANITY_DATASET=your-dataset
SANITY_API_TOKEN=your-api-token

# RustFS (S3 Compatible) Configuration
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=your-access-key
RUSTFS_SECRET_KEY=your-secret-key
RUSTFS_REGION=us-east-1
RUSTFS_BUCKET=dealio-uploads
RUSTFS_FORCE_PATH_STYLE=true
RUSTFS_PUBLIC_URL=http://localhost:9000
