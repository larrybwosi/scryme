# Database Configuration
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbpassword
POSTGRES_DB=app_db
DATABASE_URL=postgresql://dbuser:dbpassword@db:5432/app_db?schema=public

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_CRM_URL=http://localhost:3001

# Zitadel Configuration (Managed Externally)
ZITADEL_API_URL=https://zitadel.example.com
ZITADEL_ORG_ID=org-id
ZITADEL_PROJECT_ID=project-id
ZITADEL_CLIENT_ID=client-id

# Realtime Configuration
REALTIME_PROVIDER=ably
NEXT_PUBLIC_REALTIME_PROVIDER=ably
ABLY_API_KEY=your-ably-api-key
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002
INTERNAL_REALTIME_SECRET=development-realtime-secret
