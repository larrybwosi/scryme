# Realtime Configuration
# Provider can be 'ably' or 'socketio'
NEXT_PUBLIC_REALTIME_PROVIDER=ably

# Socket.io Configuration
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002

# Ably Configuration
# API key should generally not be exposed to the client directly unless using token auth.
# If using token auth, the API URL is needed.
NEXT_PUBLIC_API_URL=http://localhost:3002
