{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "websocket:default",
    "window-state:default",
    "store:default",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-write-file",
    "fs:allow-read-file",
    "fs:allow-exists",
    "fs:allow-temp-write",
    "core:window:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "hid:default",
    "deep-link:default",
    "upload:default",
    "updater:default",
    "dialog:allow-message",
    "dialog:allow-open",
    "notification:default",
    "notification:allow-check-permissions",
    "notification:allow-cancel",
    "notification:allow-permission-state",
    "notification:allow-request-permission",
    "notification:allow-notify",
    "clipboard-manager:allow-write-text",
    "http:allow-fetch-read-body",
    "fs:allow-remove",
    "hid:allow-open",
    "hid:allow-read",
    "hid:allow-write",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "updater:allow-install",
    "process:default",
    "os:default",
    "sentry:default",
    "better-posthog:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOCUMENT/*" },
        { "path": "$APPDATA/*" },
        { "path": "$DOWNLOAD/Dealio" },
        { "path": "$DOWNLOAD/Dealio/*" },
        { "path": "$DOCUMENT/Dealio" },
        { "path": "$DOCUMENT/Dealio/*" },
        { "path": "$APP_DATA/**" },
        { "path": "$APPDATA/com.dealio.pos" },
        { "path": "$APPDATA/com.dealio.pos/**" }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$DOWNLOAD" },
        { "path": "$DOWNLOAD/*" },
        { "path": "$DOWNLOAD/Dealio" },
        { "path": "$DOWNLOAD/Dealio/*" },
        { "path": "$DOCUMENT" },
        { "path": "$DOCUMENT/*" },
        { "path": "$DOCUMENT/Dealio" },
        { "path": "$DOCUMENT/Dealio/*" },
        { "path": "$APPDATA" },
        { "path": "$APPDATA/*" },
        { "path": "$APP_DATA" },
        { "path": "$APP_DATA/**" },
        { "path": "$APPDATA/com.dealio.pos" },
        { "path": "$APPDATA/com.dealio.pos/**" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://*.tauri.app" },
        { "url": "https://*:*" },
        { "url": "https://dealioerp.vercel.app" },
        { "url": "http://localhost:3000" }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "lp", "cmd": "lp", "args": true },
        { "name": "print", "cmd": "print", "args": true },
        { "name": "powershell", "cmd": "powershell", "args": true },
        { "name": "sumatrapdf", "cmd": "sumatrapdf", "args": true },
        {
          "name": "binaries/sumatrapdf",
          "cmd": "binaries/sumatrapdf",
          "args": true
        }
      ]
    }
  ]
}
