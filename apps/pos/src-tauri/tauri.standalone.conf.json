{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scryme Standalone",
  "version": "9.35.0",
  "identifier": "com.scryme.pos.standalone",
  "build": {
    "beforeDevCommand": "pnpm dev --mode standalone",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build --mode standalone",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Scryme Standalone",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "label": "main",
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' https://unpkg.com blob:; connect-src 'self' https://unpkg.com blob: https://asset.localhost; img-src 'self' asset: https://asset.localhost blob: data: https://*.unsplash.com; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'self' 'unsafe-inline'; font-src 'self' data:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:pos_standalone.db"
      ]
    }
  }
}
