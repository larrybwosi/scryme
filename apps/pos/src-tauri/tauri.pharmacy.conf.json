{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scryme Pharmacy",
  "version": "9.32.0",
  "identifier": "com.scryme.pos.pharmacy",
  "build": {
    "beforeDevCommand": "cross-env VITE_BUSINESS_MODE=pharmacy pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cross-env VITE_BUSINESS_MODE=pharmacy pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Scryme Pharmacy",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": true,
        "label": "main",
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' https://unpkg.com blob:; connect-src 'self' https://unpkg.com blob: https://asset.localhost; img-src 'self' asset: https://asset.localhost blob: data: https://*.unsplash.com; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; style-src-attr 'self' 'unsafe-inline'; font-src 'self' data:;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/sumatrapdf"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzOEJGRjBBRkYyQkY1NkMKUldSczlTdi9DditMczJ6L3NqZ3BZTGhiUS9yK2ZqUkNxZ2RrK2tlUkRPWHdhSWJJSXNSTTRLblUK",
      "endpoints": [
        "https://github.com/larrybwosi/scryme/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "sql": {
      "preload": [
        "sqlite:pos_main.db"
      ]
    }
  }
}
