{
  "name": "dealio-desktop",
  "private": true,
  "version": "3.3.0-nextgen.22",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:retail": "cross-env VITE_BUSINESS_MODE=retail tauri dev --config src-tauri/tauri.retail.conf.json --features retail",
    "dev:standalone": "tauri dev --config src-tauri/tauri.standalone.conf.json --features standalone",
    "dev:restaurant": "cross-env VITE_BUSINESS_MODE=restaurant tauri dev --config src-tauri/tauri.restaurant.conf.json --features restaurant",
    "dev:supermarket": "cross-env VITE_BUSINESS_MODE=supermarket tauri dev --config src-tauri/tauri.supermarket.conf.json --features supermarket",
    "dev:pharmacy": "cross-env VITE_BUSINESS_MODE=pharmacy tauri dev --config src-tauri/tauri.pharmacy.conf.json --features pharmacy",
    "build:retail": "cross-env VITE_BUSINESS_MODE=retail vite build && tauri build --config src-tauri/tauri.retail.conf.json --features retail",
    "build:standalone": "vite build --mode standalone && tauri build --config src-tauri/tauri.standalone.conf.json --features standalone",
    "build:restaurant": "cross-env VITE_BUSINESS_MODE=restaurant vite build && tauri build --config src-tauri/tauri.restaurant.conf.json --features restaurant",
    "build:supermarket": "cross-env VITE_BUSINESS_MODE=supermarket vite build && tauri build --config src-tauri/tauri.supermarket.conf.json --features supermarket",
    "build:pharmacy": "cross-env VITE_BUSINESS_MODE=pharmacy vite build && tauri build --config src-tauri/tauri.pharmacy.conf.json --features pharmacy",
    "exe": "npx tauri build",
    "lint:ox": "oxlint -c oxlint.json",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:frontend": "vitest run",
    "test:backend": "cd src-tauri && cargo test",
    "test:e2e": "playwright test",
    "test:all": "pnpm run test:frontend && pnpm run test:backend && pnpm run test:e2e",
    "typecheck": "tsc --noEmit",
    "lint:frontend": "pnpm run lint:ox && pnpm run typecheck",
    "lint:backend": "cd src-tauri && cargo clippy --all-features",
    "lint:all": "pnpm run lint:frontend && pnpm run lint:backend",
    "format": "npx prettier --write .",
    "cz": "cz"
  },
