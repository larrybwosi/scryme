{
  "productName": "Scryme Bakery",
  "version": "9.21.0",
  "identifier": "app.scryme.bakery",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Scryme Bakery",
        "width": 1024,
        "height": 768
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://api.scryme.tech/api/v2/bakery/update/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW51c2VkX3B1YmxpY19rZXlfZm9yX2J1aWxkX3ZlcmlmaWNhdGlvbg=="
    },
    "sql": {
      "preload": [
        "sqlite:bakery.db"
      ],
      "default": "sqlite:bakery.db"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "deb",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
