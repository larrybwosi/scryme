# --- GLOBAL ---
# The environment the app is running in (development, production, test)
NODE_ENV=development
# The port the API will listen on
PORT=3002
# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# Secret for JWT signing and verification
JWT_SECRET=your_jwt_secret_here

# --- REQUIRED ---
# Zitadel configuration
ZITADEL_DOMAIN=your-zitadel-domain
ZITADEL_CLIENT_ID=your-zitadel-client-id

# --- OPTIONAL ---
# Redis configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
# Upstash Redis (if using Upstash)
UPSTASH_REDIS_REST_URL=your_upstash_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
USE_IOREDIS_IN_PROD=false

# Internal admin secret for specific administrative tasks
INTERNAL_ADMIN_SECRET=your_internal_admin_secret

# App version
APP_VERSION=1.0.0

# GitHub Integration (e.g. for bakery updates)
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name
GITHUB_TOKEN=your_github_token

# Slack Integration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_REDIRECT_URI=your_slack_redirect_uri

# Audit Service
AUDIT_SERVICE_URL=your_audit_service_url

# Cookie domain for cross-subdomain authentication
NEXT_PUBLIC_COOKIE_DOMAIN=localhost
