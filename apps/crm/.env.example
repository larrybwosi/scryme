# Realtime Configuration
# Provider can be 'ably' or 'socketio'
NEXT_PUBLIC_REALTIME_PROVIDER=ably

# Socket.io Configuration
NEXT_PUBLIC_SOCKET_URL=http://localhost:3002

# Ably Configuration
# API key should generally not be exposed to the client directly unless using token auth.
# If using token auth, the API URL is needed.
NEXT_PUBLIC_API_URL=http://localhost:3002

# Zitadel Configuration
ZITADEL_DOMAIN=your-zitadel-domain
ZITADEL_CLIENT_ID=your-zitadel-client-id
ZITADEL_API_URL=https://auth.scryme.tech
ZITADEL_ORG_ID=your-zitadel-org-id
ZITADEL_PROJECT_ID=your-zitadel-project-id
ZITADEL_ADMIN_TOKEN=your-zitadel-admin-token

# Windmill Configuration
WINDMILL_BASE_URL=http://windmill-server:8000
WINDMILL_ADMIN_API_KEY=your-windmill-admin-api-key

# Scryme Chat / System Notification Configuration
SCRYME_CHAT_API_URL=https://api.scryme.tech
SCRYME_CHAT_CLIENT_ID=your-scryme-chat-client-id
SCRYME_CHAT_CLIENT_SECRET=your-scryme-chat-client-secret
SCRYME_SYSTEM_WORKSPACE_SLUG=your-scryme-system-workspace-slug
SCRYME_SYSTEM_CHANNEL_SLUG=your-scryme-system-channel-slug
SCRYME_WEBHOOK_SECRET=your-scryme-webhook-secret
SCRYME_ACTION_WORKFLOW_PATH=your-scryme-action-workflow-path
