# --- DATABASE CONFIGURATION ---
DATABASE_URL=postgresql://dbuser:dbpassword@localhost:5432/app_db?schema=public

# --- APP PORT CONFIGURATION ---
PORT=3006

# --- REVERSE PROXY SUPPORT & COMPATIBILITY ---
BETTER_AUTH_TRUST_HOST=true
BETTER_AUTH_URL=http://localhost:3006

# --- SECURITY CONFIGURATION ---
BETTER_AUTH_SECRET=betterauthsecret1234567890secret

# --- ZITADEL CONFIGURATION (Managed Externally) ---
ZITADEL_DOMAIN=auth.scryme.local
ZITADEL_CLIENT_ID=client-id

# --- EXTERNAL & API CONFIGURATION ---
NEXT_PUBLIC_API_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3006
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_CRM_URL=http://localhost:3001
