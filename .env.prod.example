# --- DOMAIN CONFIGURATION ---
# Set these to your local hosts or production domains
WEB_DOMAIN=scryme.local
CRM_DOMAIN=crm.scryme.local
API_DOMAIN=api.scryme.local
ZITADEL_DOMAIN=auth.scryme.local
WINDMILL_DOMAIN=windmill.scryme.local
MAILPIT_HOST=mail.scryme.local

# --- DATABASE CONFIGURATION ---
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=dbpassword
POSTGRES_DB=app_db
DATABASE_URL=postgresql://dbuser:dbpassword@db:5432/app_db?schema=public

# ZITADEL DB
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=zitadel
ZITADEL_DB_NAME=zitadel

# WINDMILL DB
WINDMILL_DB_USER=windmill
WINDMILL_DB_PASSWORD=windmill
WINDMILL_DB_NAME=windmill

# --- INFRASTRUCTURE ---
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
REDIS_URL=redis://redis:6379

# --- AUTHENTICATION (ZITADEL) ---
# Masterkey is used for initial setup and system-level access
ZITADEL_MASTERKEY=Masterkey1234!
ZITADEL_INTERNAL_API_URL=http://zitadel:8080
ZITADEL_CLIENT_ID=provide-after-setup
ZITADEL_ORG_ID=provide-after-setup
ZITADEL_PROJECT_ID=provide-after-setup

# --- APPLICATION SECRETS ---
JWT_SECRET=super-secret-random-string-change-me
BETTER_AUTH_SECRET=another-super-secret-string

# --- EXTERNAL URLS (Used by frontend to call backend via proxy) ---
NEXT_PUBLIC_API_URL=http://api.scryme.local
NEXT_PUBLIC_WEB_URL=http://scryme.local
NEXT_PUBLIC_CRM_URL=http://crm.scryme.local

# --- WINDMILL ---
WINDMILL_INTERNAL_URL=http://windmill-server:8000
