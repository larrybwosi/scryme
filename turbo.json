{
  "$schema": "https://v2-10-0.turborepo.dev/schema.json",
  "concurrency": "2",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "NEXT_PUBLIC_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "db:migrate:dev": {
      "cache": false,
      "persistent": true
    },
    "db:migrate:deploy": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:build": {
      "cache": true
    },
    "shared:build": {
      "cache": true
    },
    "auth:build": {
      "cache": true
    },

    "dev": {
      "dependsOn": ["generate", "auth:build", "shared:build", "db:build"],
      "cache": false,
      "persistent": true
    },
    "generate": {
      "dependsOn": ["^generate"],
      "inputs": ["prisma/schema/**", "prisma.config.ts"],
      "outputs": ["generated/**"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^generate"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
