    "dotenv-expand": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.19",
    "tsup": "^8.5.1"
  },
  "module": "./src/index.ts"
}
