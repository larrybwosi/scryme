{
  "name": "@repo/documents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./server": "./src/server.ts",
    "./templates/v1/*": "./src/templates/v1/*.ts",
    "./templates/v2/*": "./src/templates/v2/*.ts"
  },
  "scripts": {
    "build": "echo \"Workspace build skipped\"",
    "dev": "tsc --watch",
    "lint": "echo \"no lint script defined\"",
