    "react": "^19.2.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@testing-library/react": "^16.2.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^3.0.7",
    "jsdom": "^26.0.0",
    "tsup": "^8.5.1",
    "vitest": "^3.0.7"
  },
  "types": "./src/index.ts",
  "main": "./src/index.ts",
  "module": "./src/index.ts"
