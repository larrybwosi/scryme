{
  "name": "@repo/documents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./templates/v1/*": {
      "types": "./dist/templates/v1/*.d.ts",
      "import": "./dist/templates/v1/*.js",
      "require": "./dist/templates/v1/*.cjs"
    },
    "./templates/v2/*": {
      "types": "./dist/templates/v2/*.d.ts",
      "import": "./dist/templates/v2/*.js",
      "require": "./dist/templates/v2/*.cjs"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup",
    "dev": "tsup --watch",
    "lint": "echo \"no lint script defined\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "build:dist": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.2.1",
    "@repo/db": "workspace:*",
    "date-fns": "^4.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@testing-library/react": "^16.2.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^3.0.7",
    "jsdom": "^26.0.0",
    "tsup": "^8.5.1",
    "vitest": "^3.0.7"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js"
}
