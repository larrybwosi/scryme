{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "paths": {
      "@repo/ui/*": [
        "./src/*"
      ]
    },
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strict": false,
    "jsx": "react-jsx",
    "types": [
      "node"
    ],
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": [
    "src"
  ]
}