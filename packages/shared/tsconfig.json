{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "declaration": true,
    "outDir": "dist",
    "rootDir": "..",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "types": [
      "jest",
      "node"
    ],
    "paths": {
      "@repo/windmill/server": [
        "../windmill/src/server.ts"
      ],
      "@/*": [
        "./src/*"
      ]
    },
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": [
    "src"
  ]
}
