{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "declaration": true,
    "outDir": "dist",
    "rootDir": "..",
    "strict": false,
    "jsx": "react-jsx",
    "types": ["jest", "node"],
    "paths": {
      "@repo/windmill/server": ["../windmill/src/server.ts"],
      "@repo/db": ["../packages/db/src/index.ts"],
      "@/*": ["./src/*"]
    },
    "noImplicitAny": false,
    "strictNullChecks": false
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
