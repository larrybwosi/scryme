{
  "name": "@repo/auth",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./nest": {
      "types": "./dist/nest.d.ts",
      "import": "./dist/nest.js",
      "require": "./dist/nest.cjs"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup",
    "lint": "echo \"no lint script defined\"",
    "type-check": "tsc --noEmit",
    "dev": "tsup --watch",
    "build:dist": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/env": "workspace:*",
    "@repo/shared": "workspace:*",
    "better-auth": "^1.4.19",
    "next": "16.2.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1"
  },
  "module": "./dist/index.js"
}
