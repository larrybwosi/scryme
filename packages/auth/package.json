{
  "name": "@repo/auth",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./dist/server.js"
    },
    "./nest": {
      "types": "./src/nest.ts",
      "import": "./dist/nest.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "lint": "echo \"no lint script defined\"",
    "type-check": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/env": "workspace:*",
    "@repo/shared": "workspace:*",
    "better-auth": "^1.4.19",
    "next": "16.2.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1"
  }
}
