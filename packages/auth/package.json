{
  "name": "@repo/auth",
  "version": "0.1.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./nest": {
      "types": "./src/nest.ts",
      "import": "./dist/nest.js",
      "require": "./dist/nest.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "auth:build": "tsup",
    "lint": "echo \"no lint script defined\"",
    "type-check": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "latest",
    "@repo/db": "workspace:*",
    "@repo/env": "workspace:*",
    "@repo/shared": "workspace:*",
    "better-auth": "^1.6.23",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "next": "16.2.10",
    "tsup": "^8.5.1"
  }
}
