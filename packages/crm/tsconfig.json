{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "react-jsx",
    "ignoreDeprecations": "5.0",
    "noEmit": true,
    "outDir": "dist",
    "skipLibCheck": true,
    "strict": true,
    "types": ["jest", "node"],
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
