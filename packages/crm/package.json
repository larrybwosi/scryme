  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@repo/ui": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.33",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
