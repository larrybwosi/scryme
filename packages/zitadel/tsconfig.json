{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "skipLibCheck": true,
    "noEmit": false,
    "checkJs": false,
    "jsx": "react-jsx",
    "types": ["node"],
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strict": false,
    "rootDir": "src"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
