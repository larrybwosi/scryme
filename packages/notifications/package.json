{
  "name": "@repo/notifications",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/scryme": "workspace:*",
    "axios": "^1.6.2",
    "handlebars": "^4.7.8",
    "nodemailer": "^7.0.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup",
    "lint": "echo \"no lint script defined\"",
    "type-check": "tsc --noEmit",
    "dev": "tsup --watch",
    "build:dist": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  },
  "module": "./dist/index.js"
}
