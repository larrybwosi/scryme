{
  "name": "@repo/notifications",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/scryme": "workspace:*",
    "@repo/typescript-config": "workspace:^",
    "axios": "^1.6.2",
    "handlebars": "^4.7.8",
    "nodemailer": "^7.0.13"
  },
  "scripts": {
    "build": "tsup",
    "lint": "echo \"no lint script defined\"",
    "type-check": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  }
}
