{
  "name": "@repo/notifications",
  "version": "0.1.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./dist/server.js"
    }
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/scryme": "workspace:*",
    "@repo/typescript-config": "workspace:^",
    "axios": "^1.6.2",
    "handlebars": "^4.7.8",
    "nodemailer": "^7.0.13"
  },
  "scripts": {
    "build": "echo \"Build skipped for workspace development\"",
    "lint": "echo \"no lint script defined\"",
    "type-check": "tsc --noEmit",
    "dev": "echo \"no dev needed\"",
    "build:dist": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  },
  "module": "./src/index.ts"
}
