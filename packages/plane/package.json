{
  "name": "@repo/plane",
  "version": "1.0.0",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup",
    "dev": "tsup --watch",
    "build:dist": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.16.1"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "latest",
    "tsup": "^8.5.1"
  }
}
