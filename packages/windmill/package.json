{
  "name": "@repo/windmill",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./dist/server.js"
    }
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/scryme": "workspace:*",
    "axios": "^1.15.2",
    "clsx": "^2.1.1",
    "handlebars": "^4.7.9",
    "lucide-react": "^0.474.0",
    "nodemailer": "^7.0.13",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "tsup": "^8.5.1"
  },
  "scripts": {
    "build": "echo \"Build skipped for workspace development\"",
    "lint": "echo \"no lint script defined\"",
    "type-check": "tsc --noEmit",
    "dev": "tsc --watch",
    "build:dist": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir dist && tsup"
  },
  "module": "./src/index.ts"
}
