{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo",
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strict": false,
    "skipLibCheck": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
