model Attachment {
  id          String   @id @default(cuid())
  fileName    String?  // Optional, as a note won't have a file name
  fileUrl     String?  // Optional, as a note won't have a URL
  mimeType    String   // e.g., "image/jpeg", "application/pdf", "text/markdown"
  sizeBytes   Int?
  description String?
  content     String?  @db.Text // New field for markdown content

  uploadedAt         DateTime @default(now())
  memberId           String   // Who uploaded/created it
  uploadedByMember   Member?  @relation("MemberUploadedAttachments", fields: [memberId], references: [id])

  documentMemberId   String?
  documentMember     Member?  @relation("MemberDocuments", fields: [documentMemberId], references: [id])

  transactionId      String?
  transactions        Transaction?      @relation(fields: [transactionId], references: [id])

  purchaseId  String?
  purchase    Purchase?  @relation(fields: [purchaseId], references: [id])
  expenseId  String?
  expense    Expense?  @relation(fields: [expenseId], references: [id])
  stockBatchId  String?
  stockBatch    StockBatch?  @relation(fields: [stockBatchId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([transactionId])
  @@index([purchaseId])
  @@index([organizationId])
}

model GlobalSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("global_setting")
}

model CashDrawer {
  id             String             @id @default(cuid())
  name           String // Name for the drawer (e.g., "Till 1", "Main Register")
  locationId     String? // Optional: Link to the physical location/terminal
  location       InventoryLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  memberId       String
  member         Member             @relation(fields: [memberId], references: [id])
  openingAmount  Decimal            @db.Decimal(10, 2)
  closingAmount     Decimal?           @db.Decimal(10, 2)
  expectedAmount    Decimal?           @db.Decimal(10, 2) // Calculated based on sales and opening amount
  discrepancy       Decimal?           @db.Decimal(10, 2) // closingAmount - expectedAmount
  discrepancyReason String?
  notes             String?
  openedAt       DateTime           @default(now())
  closedAt       DateTime?
  status         DrawerStatus       @default(OPEN)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  payments Payment[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([locationId])
  @@index([openedAt])
  @@index([closedAt])
  @@index([memberId])
  @@index([organizationId])
}

enum DrawerStatus {
  OPEN // Drawer session is active
  CLOSED // Drawer session ended, counts entered
  BALANCED // Closed and closing amount matches expected amount
  DISCREPANCY // Closed and closing amount does not match expected
}

enum AuditLogAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  INVITE
  ACCESS_DENIED
  RESTORE
  EXPORT
  BULK_UPDATE
}

enum AuditLogStatus {
  SUCCESS
  FAILURE
  WARNING
}

enum AuditLogSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditEntityType {
  // --- Access & Identity ---
  USER
  MEMBER
  ROLE                // Recommended: Creating/Editing roles
  PERMISSION          // Recommended: Granting/Revoking permissions
  AUTH_CHECK

  // --- Organization & Config ---
  ORGANIZATION
  SETTINGS            // Keep for general toggles
  UNIT_DEFINITION     // NEW: SystemUnit, OrganizationUnit
  UNIT_CONVERSION     // NEW: Unit conversions logic
  ADDRESS             // NEW: Address changes

  // --- Financials ---
  TRANSACTION         // General Ledger impact
  PAYMENT_GATEWAY     // NEW: Specific Mpesa/Stripe logs
  EXPENSE
  BUDGET
  RECURRING_EXPENSE
  TAX                 // Recommended: Tax rates/rules

  // --- Operations (Inventory/Sales) ---
  PRODUCT
  CATEGORY
  STOCK_BATCH
  STOCK_ADJUSTMENT
  STOCK_MOVEMENT
  INVENTORY_LOCATION
  CASH_DRAWER
  SALE
  PURCHASE
  RETURN
  SUPPLIER
  CUSTOMER
  LOYALTY

  // --- System ---
  ATTACHMENT          // NEW: File uploads/deletions
  NOTIFICATION        // NEW: Broadcasts
  PROJECT
  ATTENDANCE
  OTHER
}

model AuditLog {
  id             String          @id @default(cuid())

  // --- Context ---
  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // --- The Actor (Who did it?) ---
  memberId       String?
  member         Member?         @relation(fields: [memberId], references: [id], onDelete: SetNull)
  // SNAPSHOT: Store these strings in case the Member record is deleted entirely
  actorName      String?         // e.g., "John Doe"
  actorEmail     String?         // e.g., "john@company.com"

  // --- The Action (What happened?) ---
  action         AuditLogAction
  entityType     AuditEntityType
  entityId       String          // The ID of the target (TransactionID, ExpenseID, etc.)

  // --- The Evidence ---
  description    String
  details        Json?           // Old vs New values (Diff)

  // --- Technical Metadata ---
  ipAddress      String?
  userAgent      String?
  status         AuditLogStatus   @default(SUCCESS)
  severity       AuditLogSeverity @default(INFO)
  performedAt    DateTime         @default(now())

  // Optimized Indexing for "Show me history of Invoice #123"
  @@index([entityType, entityId])
  // Optimized Indexing for "Show me everything John did"
  @@index([memberId])
  // Optimized Indexing for "Show me activity in Org X"
  @@index([organizationId, performedAt])

  @@map("audit_log")
}

model MpesaPaymentRequest {
  id                 String    @id @default(cuid())
  organizationId     String
  memberId           String
  paymentId          String?
  checkoutRequestId  String
  merchantRequestId  String
  amount             Decimal
  phoneNumber        String
  reference          String
  status             String // PENDING, SUCCESS, FAILED
  resultCode         Int?
  resultDescription  String?
  mpesaReceiptNumber String?
  transactionDate    DateTime?
  saleData           Json? // Store the sale data for processing after successful payment
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  saleNumber         String?

  organization Organization @relation(fields: [organizationId], references: [id])
  member       Member       @relation(fields: [memberId], references: [id])

  @@index([organizationId])
  @@index([memberId])
  @@index([checkoutRequestId])
  @@index([merchantRequestId])
  @@index([reference])
}


// Base unit types following international standards (SI and common commercial units)
enum UnitType {
  MASS        // Weight measurements (kg, g, lb, oz)
  VOLUME      // Volume measurements (L, mL, gal, oz)
  LENGTH      // Length measurements (m, cm, ft, in)
  AREA        // Area measurements (m², ft²)
  COUNT       // Discrete units (piece, dozen, pack)
  TIME        // Time measurements (hour, minute, day)
  TEMPERATURE // Temperature measurements (°C, °F, K)
  ENERGY      // Energy measurements (cal, kJ, kWh)
  CUSTOM      // Business-specific custom units
}

// Industry categories for filtering and context
enum IndustryCategory {
  UNIVERSAL   // Common across all industries
  FOOD_SERVICE
  RETAIL
  MANUFACTURING
  HEALTHCARE
  CONSTRUCTION
  AGRICULTURE
  HOSPITALITY
  OTHER
}

// System-wide standardized units (managed by platform)
model SystemUnit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core identifiers
  name         String @unique // e.g., "Kilogram", "Liter", "Piece"
  symbol       String @unique // e.g., "kg", "L", "pc"
  abbreviation String? // Alternative abbreviation if needed
  pluralName   String? // e.g., "Kilograms", "Liters" for display

  // Classification
  type     UnitType
  category IndustryCategory @default(UNIVERSAL)

  // SI System tracking
  isBaseUnit Boolean @default(false) // True for SI base units (meter, kilogram, second, etc.)
  isMetric   Boolean @default(true) // True for metric system units

  // Metadata
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int? // For display ordering

  // System conversions (bidirectional)
  conversionsFrom UnitConversion[] @relation("SystemFromUnit")
  conversionsTo   UnitConversion[] @relation("SystemToUnit")

  // Product-specific conversions (handles special cases per product)
  productConversionsFrom ProductUnitConversion[] @relation("ProductConversionFrom")
  productConversionsTo   ProductUnitConversion[] @relation("ProductConversionTo")

  // Organization custom unit references
  customUnitReferences OrganizationUnit[] @relation("BaseSystemUnit")

  // Consolidated product relations
  productVariantBase      ProductVariant[]     @relation("VariantBaseUnit")
  productVariantStocking  ProductVariant[]     @relation("VariantStockingUnit")
  variantSellingUnits     VariantSellingUnit[]
  stockBatches            StockBatch[]        @relation("StockBatchSystemUnit")
  supplierPackagingUnits  ProductSupplier[]   @relation("SupplierPackagingUnit")
  purchaseItems           PurchaseItem[]      @relation("PIOrderUnit")
  transactionItems        TransactionItem[]

  // Recipe and batch management
  recipes           Recipe[]           @relation("RecipeYieldSystemUnit")
  batches           Batch[]            @relation("BatchSystemUnit")
  templates         Template[]         @relation("TemplateSystemUnit")
  recipeIngredients RecipeIngredient[]  @relation("RecipeIngredientSystemUnit")

  @@index([type])
  @@index([category])
  @@index([isActive])
  @@map("system_unit")
}

// Organization-specific custom units
model OrganizationUnit {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Core identifiers
  name         String // e.g., "Baker's Dozen", "Serving", "Pallet (Custom)"
  symbol       String // e.g., "bd", "srv", "plt-c"
  abbreviation String?
  pluralName   String?

  // Classification
  type        UnitType
  category    IndustryCategory @default(OTHER)
  description String?
  isActive    Boolean          @default(true)

  // Optional base system unit reference (for conversions)
  baseSystemUnitId String?
  baseSystemUnit   SystemUnit? @relation("BaseSystemUnit", fields: [baseSystemUnitId], references: [id], onDelete: SetNull)

  // Conversion to base unit (if baseSystemUnitId is set)
  conversionFactor Decimal? @db.Decimal(20, 10)
  conversionOffset Decimal? @default(0) @db.Decimal(20, 10)

  // Organization unit conversions
  conversionsFrom OrgUnitConversion[] @relation("OrgFromUnit")
  conversionsTo   OrgUnitConversion[] @relation("OrgToUnit")

  // Product relations for custom units
  productVariantBase      ProductVariant[]     @relation("VariantOrgBaseUnit")
  productVariantStocking  ProductVariant[]     @relation("VariantOrgStockingUnit")
  variantSellingUnits     VariantSellingUnit[] @relation("OrgSellingUnit")
  stockBatches            StockBatch[]         @relation("StockBatchOrgUnit")
  supplierPackagingUnits  ProductSupplier[]    @relation("SupplierOrgPackagingUnit")
  purchaseItems           PurchaseItem[]       @relation("OrgPurchaseUnit")
  transactionItems        TransactionItem[]    @relation("OrgTransactionUnit")

  // Recipe and batch management
  recipes           Recipe[]           @relation("RecipeYieldOrgUnit")
  batches           Batch[]            @relation("BatchOrgUnit")
  templates         Template[]         @relation("TemplateOrgUnit")
  recipeIngredients RecipeIngredient[] @relation("RecipeIngredientOrgUnit")

  @@unique([organizationId, symbol])
  @@index([organizationId])
  @@index([type])
  @@index([isActive])
  @@map("organization_unit")
}

// Conversions between organization custom units
model OrgUnitConversion {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  fromUnitId String
  fromUnit   OrganizationUnit @relation("OrgFromUnit", fields: [fromUnitId], references: [id], onDelete: Cascade)

  toUnitId String
  toUnit   OrganizationUnit @relation("OrgToUnit", fields: [toUnitId], references: [id], onDelete: Cascade)

  // Conversion formula: toValue = (fromValue * factor) + offset
  factor Decimal @db.Decimal(20, 10)
  offset Decimal @default(0) @db.Decimal(20, 10)

  // Metadata
  isApproximate Boolean @default(false)
  notes         String?
  isActive      Boolean @default(true)

  @@unique([organizationId, fromUnitId, toUnitId])
  @@index([organizationId])
  @@index([fromUnitId])
  @@index([toUnitId])
  @@map("org_unit_conversion")
}

// Standard unit conversions (system-wide)
model UnitConversion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromUnitId String
  fromUnit   SystemUnit @relation("SystemFromUnit", fields: [fromUnitId], references: [id], onDelete: Cascade)

  toUnitId String
  toUnit   SystemUnit @relation("SystemToUnit", fields: [toUnitId], references: [id], onDelete: Cascade)

  // Conversion formula: toValue = (fromValue * factor) + offset
  factor Decimal @db.Decimal(20, 10)
  offset Decimal @default(0) @db.Decimal(20, 10)

  // Metadata
  isApproximate Boolean @default(false) // Flag for approximate conversions
  notes         String?
  isActive      Boolean @default(true)

  @@unique([fromUnitId, toUnitId])
  @@index([fromUnitId])
  @@index([toUnitId])
  @@map("unit_conversion")
}

// Product-specific unit conversions (overrides system conversions)
model ProductUnitConversion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  fromUnitId String
  fromUnit   SystemUnit @relation("ProductConversionFrom", fields: [fromUnitId], references: [id], onDelete: Restrict)

  toUnitId String
  toUnit   SystemUnit @relation("ProductConversionTo", fields: [toUnitId], references: [id], onDelete: Restrict)

  // Conversion formula
  factor Decimal @db.Decimal(20, 10)
  offset Decimal @default(0) @db.Decimal(20, 10)

  // Context
  notes    String?
  isActive Boolean @default(true)

  // Priority for when multiple conversions exist
  priority Int @default(0)

  @@unique([productId, fromUnitId, toUnitId])
  @@index([productId])
  @@index([fromUnitId])
  @@index([toUnitId])
  @@map("product_unit_conversion")
}


// ===================================
// ADDRESS MODEL
// ===================================

enum AddressType {
  BILLING
  SHIPPING
  BOTH
}

model Address {
  id         String    @id @default(cuid())
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)

  //: Can also link to B2B account
  businessAccountId String?
  businessAccount   BusinessAccount? @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)

  type AddressType @default(BOTH)

  // Address fields
  label      String? // e.g., "Home", "Office"
  street1    String
  street2    String?
  city       String
  state      String?
  postalCode String?
  country    String

  // Coordinates (optional)
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  shippingFulfillments Fulfillment[] @relation("ShippingAddress")
  billingFulfillments  Fulfillment[] @relation("BillingAddress")

  @@index([customerId])
  @@index([businessAccountId])
  @@map("address")
}
