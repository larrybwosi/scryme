// --- Standalone POS Management ---

model StandaloneSetupKey {
  id        String   @id @default(cuid())
  name      String   // Human-readable name for the intended device
  deviceId  String   // Human-assigned ID (e.g., "POS-001")
  token     String   @unique // Secure random token (redeemable)

  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("standalone_setup_key")
}

model StandaloneDevice {
  id             String   @id @default(cuid())
  name           String
  assignedId     String   // Human-assigned ID from the setup key

  // Hardware identifiers
  machineId      String   @unique
  fingerprint    String?
  serialNumber   String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  status         DeviceStatus @default(ACTIVE)

  keys           StandaloneDeviceKey[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("standalone_device")
}

model StandaloneDeviceKey {
  id        String   @id @default(cuid())
  key       String   @unique // Shorter random alphanumeric key

  deviceId  String
  device    StandaloneDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true)
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("standalone_device_key")
}
